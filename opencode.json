{
    "$schema": "https://opencode.ai/config.json",
    "share": "disabled",
    "disabled_providers": [
        "openai",
        "zen",
        "opencode"
    ],
    "instructions": [],
    "mcp": {
        "mcp-gateway": {
            "type": "local",
            "command": ["docker", "mcp", "gateway", "run"],
            "enabled": true
        },
        "playwright": {
            "type": "local",
            "command": ["npx", "@playwright/mcp@latest", "--isolated", "--browser=chrome"],
            "enabled": true
        }
    },
    "model": "github-copilot/claude-sonnet-4.6",
    "small_model": "github-copilot/claude-haiku-4.5",
    "agent": {
        "explore": {
            "model": "github-copilot/claude-haiku-4.5",
            "variant": "default"
        },
        "compaction": {
            "model": "github-copilot/claude-haiku-4.5",
            "variant": "default"
        },
        "title": {
            "model": "github-copilot/gpt-5-mini",
            "variant": "low"
        },
        "summary": {
            "model": "github-copilot/gpt-5-mini",
            "variant": "high"
        }
    },
    "default_agent": "teamlead"
}
